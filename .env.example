# Canonical site URL (no trailing slash). Used for metadata, sitemap, robots.
NEXT_PUBLIC_SITE_URL=https://smartaiautomations.com

# Cal.com booking URL, e.g. https://cal.com/tim-orourke/saas-audit
# TODO(env): set this so "Book the Free SaaS Audit" buttons and the /audit
# inline embed go live. Until set, buttons fall back to the /audit page.
NEXT_PUBLIC_CAL_URL=

# MailerLite embedded form HTML (the full embed snippet, as one line).
# TODO(env): set this to replace the placeholder worksheet form on /resources.
NEXT_PUBLIC_MAILERLITE_EMBED=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX.
# TODO(env): analytics load only when this is set.
NEXT_PUBLIC_GA4_ID=

# Meta Pixel ID. TODO(env): pixel loads only when this is set.
NEXT_PUBLIC_META_PIXEL_ID=
